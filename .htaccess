RewriteEngine On

# Redirect from old URL to new URL
RewriteCond %{HTTP_HOST} ^polandgroups\.pl$ [NC]
RewriteCond %{REQUEST_URI} ^/price/$ [NC]
RewriteRule ^(.*)$ https://polandgroup.pl/#/pl/categories [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^.*$ index.php [L,QSA]